# Copy to .env on the VM: cp .env.example .env && nano .env
#
# RULES (avoids "ton of errors"):
# - One KEY=value per line, no spaces around =
# - No quotes unless the value itself must contain them (usually avoid quotes)
# - No "export", no duplicate keys, no blank KEY=
# - Comments only on lines starting with #

# --- n8n + Postgres (required) ---
N8N_PASSWORD=change_me_strong_admin_password
N8N_ENCRYPTION_KEY=keep_existing_32_chars_if_n8n_already_setup
DB_PASSWORD=keep_existing_if_postgres_volume_exists
N8N_WEBHOOK_URL=https://n8n.mybexo.com/
N8N_BASIC_AUTH_USER=admin

# --- n8n 1.98+ (required for BEXO workflows using $env) ---
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# --- BEXO app ↔ n8n webhook (Workflow A verify node) ---
# Generate once: openssl rand -hex 32
# Must match BEXO api-server N8N_WEBHOOK_SECRET exactly
N8N_WEBHOOK_SECRET=

# --- n8n ↔ Cloud Run (Workflow A, Phase 4+) ---
# Same value as GCP Secret Manager secret: bexo-internal-secret
BEXO_INTERNAL_SECRET=

# --- Supabase (Workflow A + B) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenRouter (Workflow A — free models only) ---
OPENROUTER_API_KEY=
# Free-only on OpenRouter (see https://openrouter.ai/collections/free-models)
OPENROUTER_MODEL_SPEC=openrouter/free

# --- Phase 4 — Cloud Run codegen URL (also hardcoded in workflow JSON) ---
CLOUD_RUN_BUILD_URL=https://bexo-codegen-901109516440.us-central1.run.app

# --- Phase 5–7 (Workflow B + Worker hosting) ---
# Master guide: docs/PORTFOLIO-HOSTING-PLAN.md
# Use an API Token from Create Token — NOT the Global API Key.
# Quote values if they contain # (otherwise the rest of the line is treated as a comment).
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_TOKEN=""
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_KV_NAMESPACE_ID=
PORTFOLIO_DOMAIN=mybexo.com
