# Local development — production uses GCP Secret Manager

# --- Primary: direct APIs (recommended) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_SPEC=deepseek-chat
DEEPSEEK_MODEL_FIX=deepseek-chat
DEEPSEEK_MODEL_MODERATION=deepseek-chat
DEEPSEEK_MODEL_GENERATE_FALLBACK=deepseek-chat

KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL_GENERATE=kimi-k2-turbo-preview

# --- OpenRouter (free tier — matches n8n + Cloud Run defaults) ---
OPENROUTER_API_KEY=
OPENROUTER_FREE_ONLY=true
OPENROUTER_MODEL_SPEC=openrouter/free
OPENROUTER_MODEL_GENERATE=openrouter/free
OPENROUTER_MODEL_FIX=openrouter/free
OPENROUTER_MODEL_MODERATION=openrouter/free
OPENROUTER_FREE_MAX_TOKENS=4096

GITHUB_TOKEN=
GITHUB_ORG=bexo-sites
GCS_BUCKET=bexo-portfolios
PORTFOLIO_DOMAIN=mybexo.com
MAX_OUTPUT_TOKENS=4096

N8N_CALLBACK_URL=https://n8n.mybexo.com/webhook/bexo-build-done
BEXO_INTERNAL_SECRET=

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

MAX_BUILD_ATTEMPTS=3
RUN_LIGHTHOUSE=true
